  38:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h **** // Evaluators have to be specialized with respect to various criteria such as:
  39:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h **** //  - storage/structure/shape
  40:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h **** //  - scalar type
  41:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h **** //  - etc.
  42:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h **** // Therefore, we need specialization of evaluator providing additional template arguments for each 
  43:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h **** // We currently distinguish the following kind of evaluators:
  44:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h **** // - unary_evaluator    for expressions taking only one arguments (CwiseUnaryOp, CwiseUnaryView, Tr
  45:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h **** // - binary_evaluator   for expression taking two arguments (CwiseBinaryOp)
  46:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h **** // - ternary_evaluator   for expression taking three arguments (CwiseTernaryOp)
  47:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h **** // - product_evaluator  for linear algebra products (Product); special case of binary_evaluator bec
  48:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h **** // - mapbase_evaluator  for Map, Block, Ref
  49:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h **** // - block_evaluator    for Block (special dispatching to a mapbase_evaluator or unary_evaluator)
  50:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h **** 
  51:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h **** template< typename T,
  52:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h ****           typename Arg1Kind   = typename evaluator_traits<typename T::Arg1>::Kind,
  53:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h ****           typename Arg2Kind   = typename evaluator_traits<typename T::Arg2>::Kind,
  54:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/CoreEvaluators.h ****           typename Arg3Kind   = typename evaluator_traits<typename T::Arg3>::Kind,
