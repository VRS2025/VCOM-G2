  56:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h **** };
  57:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h **** 
  58:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h **** template <typename T>
  59:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h **** struct global_math_functions_filtering_base<
  60:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h ****     T, typename always_void<typename T::Eigen_BaseClassForSpecializationOfGlobalMathFuncImpl>::type
  61:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h ****   typedef typename T::Eigen_BaseClassForSpecializationOfGlobalMathFuncImpl type;
  62:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h **** };
  63:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h **** 
