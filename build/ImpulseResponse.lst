 662:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** 
 663:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // The macro EIGEN_CPLUSPLUS is a replacement for __cplusplus/_MSVC_LANG that
 664:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // works for both platforms, indicating the C++ standard version number.
 665:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //
ARM GAS  /var/folders/cn/msls48b51jq2dpk8d4mt2d4w0000gn/T//ccHU2Q2r.s 			page 159


 666:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // With MSVC, without defining /Zc:__cplusplus, the __cplusplus macro will
 667:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // report 199711L regardless of the language standard specified via /std.
 668:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // We need to rely on _MSVC_LANG instead, which is only available after
 669:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // VS2015.3.
 670:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #if EIGEN_COMP_MSVC_LANG > 0
 671:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_CPLUSPLUS EIGEN_COMP_MSVC_LANG
 672:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #elif EIGEN_COMP_MSVC >= 1900
 673:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_CPLUSPLUS 201103L
 674:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #elif defined(__cplusplus)
 675:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_CPLUSPLUS __cplusplus
 676:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #else
 677:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_CPLUSPLUS 0
 678:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #endif
 679:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** 
 680:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // The macro EIGEN_COMP_CXXVER defines the c++ version expected by the compiler.
 681:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // For instance, if compiling with gcc and -std=c++17, then EIGEN_COMP_CXXVER
 682:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // is defined to 17.
 683:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #if EIGEN_CPLUSPLUS >= 202002L
 684:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h ****   #define EIGEN_COMP_CXXVER 20
 685:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #elif EIGEN_CPLUSPLUS >= 201703L
 686:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h ****   #define EIGEN_COMP_CXXVER 17
 687:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #elif EIGEN_CPLUSPLUS >= 201402L
 688:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h ****   #define EIGEN_COMP_CXXVER 14
 689:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #elif EIGEN_CPLUSPLUS >= 201103L
 690:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h ****   #define EIGEN_COMP_CXXVER 11
 691:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #else
 692:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h ****   #define EIGEN_COMP_CXXVER 03
 693:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #endif
 694:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** 
 695:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** 
 696:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // The macros EIGEN_HAS_CXX?? defines a rough estimate of available c++ features
 697:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // but in practice we should not rely on them but rather on the availability of
 698:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // individual features as defined later.
 699:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // This is why there is no EIGEN_HAS_CXX17.
 700:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #if EIGEN_MAX_CPP_VER < 14 || EIGEN_COMP_CXXVER < 14 || \
 701:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h ****   (EIGEN_COMP_MSVC && EIGEN_COMP_MSVC < 1900) || \
 702:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h ****   (EIGEN_COMP_ICC && EIGEN_COMP_ICC < 1500) || \
 703:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h ****   (EIGEN_COMP_NVCC && EIGEN_COMP_NVCC < 80000) || \
 704:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h ****   (EIGEN_COMP_CLANG_STRICT && EIGEN_COMP_CLANG < 390) || \
 705:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h ****   (EIGEN_COMP_CLANGAPPLE && EIGEN_COMP_CLANGAPPLE < 9000000) || \
 706:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h ****   (EIGEN_COMP_GNUC_STRICT && EIGEN_COMP_GNUC < 510)
