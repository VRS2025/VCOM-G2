  69:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
ARM GAS  C:\Users\vinok\AppData\Local\Temp\ccn61esS.s 			page 25


  70:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * The first three template parameters are required:
  71:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * \tparam Scalar_ Numeric type, e.g. float, double, int or std::complex<float>.
  72:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *                 User defined scalar types are supported as well (see \ref user_defined_scalars "
  73:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * \tparam Rows_ Number of rows, or \b Dynamic
  74:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * \tparam Cols_ Number of columns, or \b Dynamic
  75:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
  76:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * The remaining template parameters are optional -- in most cases you don't have to worry about th
  77:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * \tparam Options_ A combination of either \b #RowMajor or \b #ColMajor, and of either
  78:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *                 \b #AutoAlign or \b #DontAlign.
  79:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *                 The former controls \ref TopicStorageOrders "storage order", and defaults to col
  80:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * controls alignment, which is required for vectorization. It defaults to aligning matrices except
  81:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * aren't a multiple of the packet size. \tparam MaxRows_ Maximum number of rows. Defaults to \a Ro
  82:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * "note"). \tparam MaxCols_ Maximum number of columns. Defaults to \a Cols_ (\ref maxrows "note").
  83:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
  84:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * Eigen provides a number of typedefs covering the usual cases. Here are some examples:
  85:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
  86:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * \li \c Matrix2d is a 2x2 square matrix of doubles (\c Matrix<double, 2, 2>)
  87:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * \li \c Vector4f is a vector of 4 floats (\c Matrix<float, 4, 1>)
  88:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * \li \c RowVector3i is a row-vector of 3 ints (\c Matrix<int, 1, 3>)
  89:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
  90:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * \li \c MatrixXf is a dynamic-size matrix of floats (\c Matrix<float, Dynamic, Dynamic>)
  91:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * \li \c VectorXf is a dynamic-size vector of floats (\c Matrix<float, Dynamic, 1>)
  92:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
  93:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * \li \c Matrix2Xf is a partially fixed-size (dynamic-size) matrix of floats (\c Matrix<float, 2, 
  94:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * \li \c MatrixX3d is a partially dynamic-size (fixed-size) matrix of double (\c Matrix<double, Dy
  95:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
  96:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * See \link matrixtypedefs this page \endlink for a complete list of predefined \em %Matrix and \e
  97:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
  98:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * You can access elements of vectors and matrices using normal subscripting:
  99:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
 100:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * \code
 101:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * Eigen::VectorXd v(10);
 102:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * v[0] = 0.1;
 103:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * v[1] = 0.2;
 104:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * v(0) = 0.3;
 105:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * v(1) = 0.4;
 106:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
 107:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * Eigen::MatrixXi m(10, 10);
 108:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * m(0, 1) = 1;
 109:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * m(0, 2) = 2;
 110:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * m(0, 3) = 3;
 111:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * \endcode
 112:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
 113:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * This class can be extended with the help of the plugin mechanism described on the page
 114:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * \ref TopicCustomizing_Plugins by defining the preprocessor symbol \c EIGEN_MATRIX_PLUGIN.
 115:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
 116:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * <i><b>Some notes:</b></i>
 117:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
 118:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * <dl>
 119:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * <dt><b>\anchor dense Dense versus sparse:</b></dt>
 120:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * <dd>This %Matrix class handles dense, not sparse matrices and vectors. For sparse matrices and v
 121:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * Sparse module.
 122:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
 123:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * Dense matrices and vectors are plain usual arrays of coefficients. All the coefficients are stor
 124:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * contiguous array. This is unlike Sparse matrices and vectors where the coefficients are stored a
 125:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * coefficients.</dd>
 126:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
ARM GAS  C:\Users\vinok\AppData\Local\Temp\ccn61esS.s 			page 26


 127:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * <dt><b>\anchor fixedsize Fixed-size versus dynamic-size:</b></dt>
 128:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * <dd>Fixed-size means that the numbers of rows and columns are known at compile-time. In this cas
 129:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * the array of coefficients as a fixed-size array, as a class member. This makes sense for very sm
 130:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * typically up to 4x4, sometimes up to 16x16. Larger matrices should be declared as dynamic-size e
 131:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * know their size at compile-time.
 132:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
 133:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * Dynamic-size means that the numbers of rows or columns are not necessarily known at compile-time
 134:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * are runtime variables, and the array of coefficients is allocated dynamically on the heap.
 135:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
 136:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * Note that \em dense matrices, be they Fixed-size or Dynamic-size, <em>do not</em> expand dynamic
 137:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * a std::map. If you want this behavior, see the Sparse module.</dd>
 138:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  *
 139:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * <dt><b>\anchor maxrows MaxRows_ and MaxCols_:</b></dt>
 140:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Matrix.h ****  * <dd>In most cases, one just leaves these parameters to the default values.
