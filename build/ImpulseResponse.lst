  81:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/XprHelper.h **** // promote_scalar_arg is an helper used in operation between an expression and a scalar, like:
  82:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/XprHelper.h **** //    expression * scalar
  83:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/XprHelper.h **** // Its role is to determine how the type T of the scalar operand should be promoted given the scala
  84:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/XprHelper.h **** // the given expression. The IsSupported template parameter must be provided by the caller as:
  85:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/XprHelper.h **** // internal::has_ReturnType<ScalarBinaryOpTraits<ExprScalar,T,op> >::value using the proper order f
  86:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/XprHelper.h **** // Then the logic is as follows:
  87:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/XprHelper.h **** //  - if the operation is natively supported as defined by IsSupported, then the scalar type is not
  88:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/XprHelper.h **** //  returned.
  89:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/XprHelper.h **** //  - otherwise, NumTraits<ExprScalar>::Literal is returned if T is implicitly convertible to
  90:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/XprHelper.h **** //  NumTraits<ExprScalar>::Literal AND that this does not imply a float to integer conversion.
  91:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/XprHelper.h **** //  - otherwise, ExprScalar is returned if T is implicitly convertible to ExprScalar AND that this 
  92:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/XprHelper.h **** //  float to integer conversion.
