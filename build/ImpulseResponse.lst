 676:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // The macro EIGEN_CPLUSPLUS is a replacement for __cplusplus/_MSVC_LANG that
 677:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // works for both platforms, indicating the C++ standard version number.
 678:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //
 679:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // With MSVC, without defining /Zc:__cplusplus, the __cplusplus macro will
 680:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // report 199711L regardless of the language standard specified via /std.
 681:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // We need to rely on _MSVC_LANG instead, which is only available after
 682:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // VS2015.3.
 683:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #if EIGEN_COMP_MSVC_LANG > 0
 684:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_CPLUSPLUS EIGEN_COMP_MSVC_LANG
 685:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #elif EIGEN_COMP_MSVC >= 1900
 686:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_CPLUSPLUS 201103L
 687:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #elif defined(__cplusplus)
 688:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_CPLUSPLUS __cplusplus
 689:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #else
 690:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_CPLUSPLUS 0
 691:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #endif
 692:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** 
 693:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // The macro EIGEN_COMP_CXXVER defines the c++ version expected by the compiler.
 694:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // For instance, if compiling with gcc and -std=c++17, then EIGEN_COMP_CXXVER
 695:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // is defined to 17.
 696:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #if EIGEN_CPLUSPLUS >= 202002L
 697:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_COMP_CXXVER 20
 698:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #elif EIGEN_CPLUSPLUS >= 201703L
 699:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_COMP_CXXVER 17
 700:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #elif EIGEN_CPLUSPLUS >= 201402L
 701:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_COMP_CXXVER 14
 702:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #elif EIGEN_CPLUSPLUS >= 201103L
 703:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_COMP_CXXVER 11
 704:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #else
 705:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_COMP_CXXVER 03
 706:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #endif
 707:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** 
 708:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // The macros EIGEN_HAS_CXX?? defines a rough estimate of available c++ features
 709:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // but in practice we should not rely on them but rather on the availability of
