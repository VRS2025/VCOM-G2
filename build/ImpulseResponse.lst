 269:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Redux.h ****         res = func(res, eval.coeffByOuterInner(i, j));
 270:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Redux.h ****     return res;
