 882:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** 
 883:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // this macro allows to get rid of linking errors about multiply defined functions.
 884:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //  - static is not very good because it prevents definitions from different object files to be mer
 885:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //           So static causes the resulting linked executable to be bloated with multiple copies of
 886:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //  - inline is not perfect either as it unwantedly hints the compiler toward inlining the function
 887:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_DECLARE_FUNCTION_ALLOWING_MULTIPLE_DEFINITIONS EIGEN_DEVICE_FUNC
 888:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_DEFINE_FUNCTION_ALLOWING_MULTIPLE_DEFINITIONS EIGEN_DEVICE_FUNC inline
