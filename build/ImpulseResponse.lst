 590:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // If either EIGEN_CUDA_ARCH or EIGEN_HIP_DEVICE_COMPILE is defined, then define EIGEN_GPU_COMPILE_
 591:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //
 592:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_GPU_COMPILE_PHASE
 593:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //
 594:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // GPU compilers (HIPCC, NVCC) typically do two passes over the source code,
 595:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //   + one to compile the source for the "host" (ie CPU)
 596:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //   + another to compile the source for the "device" (ie. GPU)
 597:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //
 598:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // Code that needs to enabled only during the either the "host" or "device" compilation phase
 599:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // needs to be guarded with a macro that indicates the current compilation phase
 600:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //
 601:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // EIGEN_HIP_DEVICE_COMPILE implies the device compilation phase in HIP
