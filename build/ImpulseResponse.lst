 670:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // A Clang feature extension to determine compiler features.
 671:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // We use it to determine 'cxx_rvalue_references'
 672:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #ifndef __has_feature
 673:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define __has_feature(x) 0
