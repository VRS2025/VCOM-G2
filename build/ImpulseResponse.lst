 443:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h ****   if (numext::equal_strict(um1, Scalar(-1))) {
 444:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h ****     return RealScalar(-1);
 445:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h ****   }
 446:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h **** 
 447:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h ****   EIGEN_USING_STD(log);
 448:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h ****   Scalar logu = log(u);
