 875:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // All functions callable from CUDA/HIP code must be qualified with __device__
 876:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #elif defined(EIGEN_GPUCC)
 877:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h ****     #define EIGEN_DEVICE_FUNC __host__ __device__
 878:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #else
 879:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h ****   #define EIGEN_DEVICE_FUNC
