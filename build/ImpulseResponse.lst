  16:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h **** 
  17:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h **** /** \class Stride
  18:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * \ingroup Core_Module
  19:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   *
  20:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * \brief Holds strides information for Map
  21:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   *
  22:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * This class holds the strides information for mapping arrays with strides with class Map.
  23:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   *
  24:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * It holds two values: the inner stride and the outer stride.
  25:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   *
  26:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * The inner stride is the pointer increment between two consecutive entries within a given row of
  27:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * row-major matrix or within a given column of a column-major matrix.
ARM GAS  /var/folders/cn/msls48b51jq2dpk8d4mt2d4w0000gn/T//ccHU2Q2r.s 			page 74


  28:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   *
  29:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * The outer stride is the pointer increment between two consecutive rows of a row-major matrix or
  30:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * between two consecutive columns of a column-major matrix.
  31:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   *
  32:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * These two values can be passed either at compile-time as template parameters, or at runtime as
  33:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * arguments to the constructor.
  34:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   *
  35:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * Indeed, this class takes two template parameters:
  36:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   *  \tparam OuterStrideAtCompileTime_ the outer stride, or Dynamic if you want to specify it at ru
  37:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   *  \tparam InnerStrideAtCompileTime_ the inner stride, or Dynamic if you want to specify it at ru
  38:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   *
  39:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * Here is an example:
  40:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * \include Map_general_stride.cpp
  41:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * Output: \verbinclude Map_general_stride.out
  42:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   *
  43:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * Both strides can be negative. However, a negative stride of -1 cannot be specified at compile t
  44:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * because of the ambiguity with Dynamic which is defined to -1 (historically, negative strides we
  45:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * not allowed).
  46:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   *
  47:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * Note that for compile-time vectors (ColsAtCompileTime==1 or RowsAtCompile==1),
  48:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * the inner stride is the pointer increment between two consecutive elements,
  49:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * regardless of storage layout.
  50:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   *
  51:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   * \sa class InnerStride, class OuterStride, \ref TopicStorageOrders
  52:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   */
  53:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h **** template<int OuterStrideAtCompileTime_, int InnerStrideAtCompileTime_>
  54:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h **** class Stride
  55:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h **** {
  56:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/Stride.h ****   public:
