 708:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #endif
 709:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** 
 710:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // Does the compiler support C99?
 711:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // Need to include <cmath> to make sure _GLIBCXX_USE_C99 gets defined
