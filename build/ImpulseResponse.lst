  24:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** 
  25:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** // Try to determine automatically if malloc is already aligned.
  26:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** 
  27:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** // On 64-bit systems, glibc's malloc returns 16-byte-aligned pointers, see:
  28:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** //   http://www.gnu.org/s/libc/manual/html_node/Aligned-Memory-Blocks.html
  29:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** // This is true at least since glibc 2.8.
  30:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** // This leaves the question how to detect 64-bit. According to this document,
  31:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** //   http://gcc.fyxm.net/summit/2003/Porting%20to%2064%20bit.pdf
  32:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** // page 114, "[The] LP64 model [...] is used by all 64-bit UNIX ports" so it's indeed
  33:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** // quite safe, at least within the context of glibc, to equate 64-bit with LP64.
  34:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** #if defined(__GLIBC__) && ((__GLIBC__>=2 && __GLIBC_MINOR__ >= 8) || __GLIBC__>2) \
  35:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h ****  && defined(__LP64__) && ! defined( __SANITIZE_ADDRESS__ ) && (EIGEN_DEFAULT_ALIGN_BYTES == 16)
  36:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h ****   #define EIGEN_GLIBC_MALLOC_ALREADY_ALIGNED 1
  37:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** #else
  38:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h ****   #define EIGEN_GLIBC_MALLOC_ALREADY_ALIGNED 0
  39:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** #endif
  40:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** 
  41:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** // FreeBSD 6 seems to have 16-byte aligned malloc
  42:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** //   See http://svn.freebsd.org/viewvc/base/stable/6/lib/libc/stdlib/malloc.c?view=markup
  43:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** // FreeBSD 7 seems to have 16-byte aligned malloc except on ARM and MIPS architectures
  44:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** //   See http://svn.freebsd.org/viewvc/base/stable/7/lib/libc/stdlib/malloc.c?view=markup
  45:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Memory.h **** #if defined(__FreeBSD__) && !(EIGEN_ARCH_ARM || EIGEN_ARCH_MIPS) && (EIGEN_DEFAULT_ALIGN_BYTES == 1
