 813:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** 
 814:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // EIGEN_STRONG_INLINE is a stronger version of the inline, using __forceinline on MSVC,
 815:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // but it still doesn't use GCC's always_inline. This is useful in (common) situations where MSVC n
 816:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // but GCC is still doing fine with just inline.
 817:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #ifndef EIGEN_STRONG_INLINE
 818:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #if (EIGEN_COMP_MSVC || EIGEN_COMP_ICC) && !defined(EIGEN_GPUCC)
 819:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_STRONG_INLINE __forceinline
 820:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #else
 821:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_STRONG_INLINE inline
 822:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #endif
 823:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #endif
 824:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** 
 825:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // EIGEN_ALWAYS_INLINE is the strongest, it has the effect of making the function inline and adding
 826:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // attribute to maximize inlining. This should only be used when really necessary: in particular,
 827:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // it uses __attribute__((always_inline)) on GCC, which most of the time is useless and can severel
 828:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // FIXME with the always_inline attribute,
 829:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #if EIGEN_COMP_GNUC && !defined(SYCL_DEVICE_ONLY)
 830:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_ALWAYS_INLINE __attribute__((always_inline)) inline
 831:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #else
 832:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_ALWAYS_INLINE EIGEN_STRONG_INLINE
 833:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #endif
 834:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** 
 835:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #if EIGEN_COMP_GNUC
 836:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_DONT_INLINE __attribute__((noinline))
