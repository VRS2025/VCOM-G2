 568:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //
 569:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #define EIGEN_GPUCC
 570:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //
 571:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // EIGEN_HIPCC implies the HIP compiler and is used to tweak Eigen code for use in HIP kernels
 572:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // EIGEN_CUDACC implies the CUDA compiler and is used to tweak Eigen code for use in CUDA kernels
 573:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //
 574:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // In most cases the same tweaks are required to the Eigen code to enable in both the HIP and CUDA 
