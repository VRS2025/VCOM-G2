 427:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h **** // This implementation is based on GSL Math's expm1.
 428:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h **** namespace std_fallback {
 429:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h **** // fallback expm1 implementation in case there is no expm1(Scalar) function in namespace of Scalar,
 430:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h **** // or that there is no suitable std::expm1 function available. Implementation
 431:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/MathFunctions.h **** // attributed to Kahan. See: http://www.plunk.org/~hatch/rightway.php.
