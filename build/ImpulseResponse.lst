 647:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // Detect Compiler/Architecture/OS specific features
 648:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** //------------------------------------------------------------------------------------------
 649:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** 
 650:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // Cross compiler wrapper around LLVM's __has_builtin
 651:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #ifdef __has_builtin
 652:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #  define EIGEN_HAS_BUILTIN(x) __has_builtin(x)
 653:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #else
 654:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #  define EIGEN_HAS_BUILTIN(x) 0
 655:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #endif
 656:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** 
 657:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // A Clang feature extension to determine compiler features.
 658:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** // We use it to determine 'cxx_rvalue_references'
 659:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** #ifndef __has_feature
 660:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/Macros.h **** # define __has_feature(x) 0
