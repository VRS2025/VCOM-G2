  50:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h **** // A simple wrapper around an integral value to provide the eval method.
  51:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h **** // We could also use a free-function symbolic_eval...
  52:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h **** template<typename IndexType=Index>
  53:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h **** class ValueExpr {
  54:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h **** public:
