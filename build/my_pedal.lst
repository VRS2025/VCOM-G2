1375:my_pedal.cpp  **** static void detectPitch()
1376:my_pedal.cpp  **** {
1377:my_pedal.cpp  ****     int start = g_tunerIdx;
1378:my_pedal.cpp  ****     float mean = 0.0f, energy = 0.0f;
1379:my_pedal.cpp  ****     for (int i = 0; i < TUNER_N; i++)
1380:my_pedal.cpp  ****     {
1381:my_pedal.cpp  ****         float v = g_tunerBuf[(start + i) % TUNER_N];
1382:my_pedal.cpp  ****         g_acBuf[i] = v; mean += v;
1383:my_pedal.cpp  ****     }
1384:my_pedal.cpp  ****     mean /= TUNER_N;
1385:my_pedal.cpp  ****     for (int i = 0; i < TUNER_N; i++) { g_acBuf[i] -= mean; energy += g_acBuf[i] * g_acBuf[i]; }
1386:my_pedal.cpp  ****     if (energy < 0.002f) return; // čéąĖčłąĖąĮą░ -> ą┤ąĄčĆąČąĖą╝ ą┐ąŠčüą╗ąĄą┤ąĮčÄčÄ ąĮąŠčéčā
1387:my_pedal.cpp  **** 
1388:my_pedal.cpp  ****     int win = TUNER_N - TLAG_MAX;
1389:my_pedal.cpp  ****     float maxPeak = 0.0f;
1390:my_pedal.cpp  ****     for (int lag = TLAG_MIN; lag <= TLAG_MAX; lag++)
1391:my_pedal.cpp  ****     {
1392:my_pedal.cpp  ****         float ac = 0.0f, m = 0.0f;
1393:my_pedal.cpp  ****         for (int i = 0; i < win; i++)
1394:my_pedal.cpp  ****         {
1395:my_pedal.cpp  ****             float a = g_acBuf[i], b = g_acBuf[i + lag];
1396:my_pedal.cpp  ****             ac += a * b;
1397:my_pedal.cpp  ****             m += a * a + b * b;
1398:my_pedal.cpp  ****         }
1399:my_pedal.cpp  ****         float v = (m > 1e-9f) ? (2.0f * ac / m) : 0.0f; // NSDF ą▓ [-1,1]
1400:my_pedal.cpp  ****         g_acCorr[lag] = v;
1401:my_pedal.cpp  ****         if (v > maxPeak) maxPeak = v;
1402:my_pedal.cpp  ****     }
1403:my_pedal.cpp  ****     if (maxPeak < 0.3f) return; // čüą╗ą░ą▒ą░čÅ ą┐ąĄčĆąĖąŠą┤ąĖčćąĮąŠčüčéčī -> ą┤ąĄčĆąČąĖą╝ ą┐ąŠčüą╗
1404:my_pedal.cpp  **** 
1405:my_pedal.cpp  ****     // ą¤ąĄčĆą▓čŗą╣ ą╗ąŠą║ą░ą╗čīąĮčŗą╣ ą┐ąĖą║ ą▓čŗčłąĄ 0.75*ą╝ą░ą║čü ŌĆö čŹčéąŠ ąŠčüąĮąŠą▓ąĮąŠą╣ čé
1406:my_pedal.cpp  ****     float thresh = 0.75f * maxPeak;
1407:my_pedal.cpp  ****     int bestLag = -1;
1408:my_pedal.cpp  ****     for (int lag = TLAG_MIN + 1; lag < TLAG_MAX; lag++)
