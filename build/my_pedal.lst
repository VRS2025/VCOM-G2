  36:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.Init(config.transport_config); // čüą▒čĆąŠčü + SPI ą┤ąĄą╗ą░ąĄčé čéčĆą░ąĮčüą┐ąŠčĆ
  37:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(0xAE);             // display off
  38:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(BIAS);             // LCD bias 1/9
