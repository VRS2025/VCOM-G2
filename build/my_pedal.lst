  60:GuitarPedal/Hardware-Modules/st7565.h ****     size_t Width() const { return width; }
  61:GuitarPedal/Hardware-Modules/st7565.h ****     size_t Height() const { return height; }
  62:GuitarPedal/Hardware-Modules/st7565.h **** 
  63:GuitarPedal/Hardware-Modules/st7565.h ****     void DrawPixel(uint_fast8_t x, uint_fast8_t y, bool on)
  64:GuitarPedal/Hardware-Modules/st7565.h ****     {
  65:GuitarPedal/Hardware-Modules/st7565.h ****         if(x >= width || y >= height)
  66:GuitarPedal/Hardware-Modules/st7565.h ****             return;
  67:GuitarPedal/Hardware-Modules/st7565.h ****         if(on)
  68:GuitarPedal/Hardware-Modules/st7565.h ****             buffer_[x + (y / 8) * width] |= (1 << (y % 8));
  69:GuitarPedal/Hardware-Modules/st7565.h ****         else
  70:GuitarPedal/Hardware-Modules/st7565.h ****             buffer_[x + (y / 8) * width] &= ~(1 << (y % 8));
  71:GuitarPedal/Hardware-Modules/st7565.h ****     }
  72:GuitarPedal/Hardware-Modules/st7565.h **** 
  73:GuitarPedal/Hardware-Modules/st7565.h ****     void Fill(bool on)
  74:GuitarPedal/Hardware-Modules/st7565.h ****     {
  75:GuitarPedal/Hardware-Modules/st7565.h ****         for(size_t i = 0; i < sizeof(buffer_); i++)
  76:GuitarPedal/Hardware-Modules/st7565.h ****             buffer_[i] = on ? 0xFF : 0x00;
  77:GuitarPedal/Hardware-Modules/st7565.h ****     }
