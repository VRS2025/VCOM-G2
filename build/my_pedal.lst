  17:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h **** /** \namespace Eigen::symbolic
  18:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * \ingroup Core_Module
  19:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   *
  20:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * This namespace defines a set of classes and functions to build and evaluate symbolic expression
  21:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * Here is a simple example:
  22:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   *
  23:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * \code
  24:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * // First step, defines symbols:
  25:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * struct x_tag {};  static const symbolic::SymbolExpr<x_tag> x;
  26:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * struct y_tag {};  static const symbolic::SymbolExpr<y_tag> y;
  27:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * struct z_tag {};  static const symbolic::SymbolExpr<z_tag> z;
  28:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   *
  29:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * // Defines an expression:
  30:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * auto expr = (x+3)/y+z;
  31:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   *
  32:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * // And evaluate it: (c++14)
  33:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * std::cout << expr.eval(x=6,y=3,z=-13) << "\n";
  34:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   *
  35:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * \endcode
  36:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   *
  37:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * It is currently only used internally to define and manipulate the
  38:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * Eigen::placeholders::last and Eigen::placeholders::lastp1 symbols in
  39:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   * Eigen::seq and Eigen::seqN.
  40:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   *
  41:../VCOM-G1/GuitarPedal/eigen/Eigen/src/Core/util/SymbolicIndex.h ****   */
