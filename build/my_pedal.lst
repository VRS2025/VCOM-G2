  21:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h **** class PersistentStorage
  22:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h **** {
  23:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****   public:
  24:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     /** State of the storage. 
  25:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *  When created, prior to initialiation, the state will be Unknown
  26:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *  
  27:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *  During initialization, the state will be changed to either FACTORY,
  28:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *  or USER. 
  29:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      * 
  30:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *  If this is the first time these settings are being written to the
  31:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *  target address, the defaults will be written to that location,
  32:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *  and the state will be set to FACTORY.
  33:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      * 
  34:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *  Once the first user-trigger save has been made, the state will be 
  35:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *  updated to USER to indicate that the defaults have overwritten.
  36:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      */
  37:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     enum class State
  38:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     {
  39:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         UNKNOWN = 0,
  40:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         FACTORY = 1,
  41:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         USER    = 2,
  42:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     };
  43:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h **** 
