  65:../VCOM-G1/GuitarPedal/libDaisy/src/hid/switch.h ****     inline bool RisingEdge() const { return updated_ ? state_ == 0x7f : false; }
  66:../VCOM-G1/GuitarPedal/libDaisy/src/hid/switch.h **** 
  67:../VCOM-G1/GuitarPedal/libDaisy/src/hid/switch.h ****     /** \return true if the button was just released */
  68:../VCOM-G1/GuitarPedal/libDaisy/src/hid/switch.h ****     inline bool FallingEdge() const
  69:../VCOM-G1/GuitarPedal/libDaisy/src/hid/switch.h ****     {
  70:../VCOM-G1/GuitarPedal/libDaisy/src/hid/switch.h ****         return updated_ ? state_ == 0x80 : false;
