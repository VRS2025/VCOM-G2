 193:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h **** /** This class is intended as a intermediary class for your actual implementation of the OneBitGrap
 194:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *  interface. It uses the CRTP design pattern where the template argument is the child class. It p
 195:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *  implementations for most of the functions, except DrawPixel(), Update() and Fill(), which you'l
 196:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *  to provide in your child class.
 197:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *  The main goal of this class is to provide common drawing functions without relying on massive a
 198:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *  virtual function calls that would result in a performance loss. To achieve this, any drawing fu
 199:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *  is implemented here and internally calls other drawing functions (e.g. DrawRect() which interna
 200:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *  DrawPixel() and DrawLine()) makes these calls via the qualified name of these functions to expl
 201:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *  suppress the virtual dispatch mechanism like this:
 202:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  * 
 203:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *      ChildType::DrawPixel(...); // no virtual function call; direct call into the child class fu
 204:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *  
 205:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *  To create a custom OneBitGraphicsDisplay implementation, you can 
 206:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *  A) inherit from OneBitGraphicsDisplay directly and provide all the drawing functions yourself
 207:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *  B) Inherit from OneBitGraphicsDisplayImpl and only provide DrawPixel(), Fill() and Update()
 208:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *     like this:
 209:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *  
 210:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *      class MyDisplayClass : public OneBitGraphicsDisplayImpl<MyDisplayClass> 
 211:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *      {
 212:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *      public:
 213:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *          void Fill() override { ... };
 214:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *          void DrawPixel(uint_fast8_t x, uint_fast8_t y, bool on) override { ... };
 215:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *          void Update() override { ... }
 216:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *      };
 217:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  *  
 218:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****  */
 219:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h **** template <class ChildType>
 220:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h **** class OneBitGraphicsDisplayImpl : public OneBitGraphicsDisplay
 221:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h **** {
 222:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****   public:
 223:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****     OneBitGraphicsDisplayImpl() {}
