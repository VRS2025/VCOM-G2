  51:GuitarPedal/Hardware-Modules/st7565.h ****     // ąÜąŠąĮčéčĆą░čüčé (electronic volume) ST7565: ą║ąŠą╝ą░ąĮą┤ą░ 0x81 + ąĘąĮą░čćąĄąĮąĖąĄ 0..63.
  52:GuitarPedal/Hardware-Modules/st7565.h ****     void SetContrast(uint8_t v)
  53:GuitarPedal/Hardware-Modules/st7565.h ****     {
  54:GuitarPedal/Hardware-Modules/st7565.h ****         if(v > 0x3F)
