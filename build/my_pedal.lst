  56:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     /** Initialize Storage class
  57:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *
  58:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *  The values in this class will be stored as the default
  59:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *  for restoration to 'factory' settings.
  60:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *
  61:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *  \param defaults should be a setting structure containing the default values.
  62:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *      this will be updated to contain the stored data.
  63:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *  \param address_offset offset for location on the QSPI chip (offset to base address of devic
  64:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      *      This defaults to the first address on the chip, and will be masked to the nearest multi
  65:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****      **/
  66:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     void Init(const SettingStruct &defaults, uint32_t address_offset = 0)
  67:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     {
  68:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         default_settings_ = defaults;
  69:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         settings_         = defaults;
  70:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         address_offset_   = address_offset & (uint32_t)(~0xff);
  71:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         auto storage_data
  72:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****             = reinterpret_cast<SaveStruct *>(qspi_.GetData(address_offset_));
  73:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h **** 
  74:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         // check to see if the state is already in use.
  75:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         State cur_state = storage_data->storage_state;
  76:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         if(cur_state != State::FACTORY && cur_state != State::USER)
  77:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         {
  78:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****             // Initialize the Data store State::FACTORY, and the DefaultSettings
  79:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****             state_ = State::FACTORY;
  80:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****             StoreSettingsIfChanged();
  81:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         }
  82:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         else
  83:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         {
  84:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****             state_    = cur_state;
  85:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****             settings_ = storage_data->user_data;
  86:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****         }
  87:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     }
  88:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h **** 
  89:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     /** Returns the state of the Persistent Data */
  90:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     State GetState() const { return state_; }
  91:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h **** 
  92:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     /** Returns a reference to the setting struct */
  93:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     SettingStruct &GetSettings() { return settings_; }
  94:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h **** 
  95:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     /** Performs the save operation, storing the storage */
  96:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     void Save()
  97:../VCOM-G1/GuitarPedal/libDaisy/src/util/PersistentStorage.h ****     {
