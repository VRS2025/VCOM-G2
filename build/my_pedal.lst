 237:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****         int_fast16_t error2;
 238:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h **** 
 239:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****         // If we write "ChildType::DrawPixel(x2, y2, on);", we end up with
 240:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****         // all sorts of weird compiler errors when the Child class is a template
 241:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****         // class. The only way around this is to use this very verbose syntax:
 242:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****         ((ChildType*)(this))->ChildType::DrawPixel(x2, y2, on);
 243:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h **** 
 244:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****         while((x1 != x2) || (y1 != y2))
 245:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****         {
 246:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****             ((ChildType*)(this))->ChildType::DrawPixel(x1, y1, on);
 247:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****             error2 = error * 2;
 248:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****             if(error2 > -deltaY)
 249:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****             {
 250:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****                 error -= deltaY;
 251:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****                 x1 += signX;
 252:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****             }
 253:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h **** 
 254:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****             if(error2 < deltaX)
 255:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****             {
 256:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****                 error += deltaX;
 257:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****                 y1 += signY;
 258:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****             }
 259:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****         }
 260:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****     }
 261:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h **** 
 262:../VCOM-G1/GuitarPedal/libDaisy/src/hid/disp/display.h ****     void DrawRect(uint_fast8_t x1,
