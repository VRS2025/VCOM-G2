  35:GuitarPedal/Hardware-Modules/st7565.h ****     {
  36:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.Init(config.transport_config); // čüą▒čĆąŠčü + SPI ą┤ąĄą╗ą░ąĄčé čéčĆą░ąĮčüą┐ąŠčĆ
  37:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(0xAE);             // display off
  38:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(BIAS);             // LCD bias 1/9
  39:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(ADC_DIR);          // ADC (ąĘąĄčĆą║ą░ą╗ąŠ X)
  40:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(COM_DIR);          // COM (ą┐ąĄčĆąĄą▓ąŠčĆąŠčé Y)
  41:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(RES_RATIO);        // V5 resistor ratio
  42:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(0x2F);             // power: booster+regulator+follower ON
  43:GuitarPedal/Hardware-Modules/st7565.h ****         System::Delay(50);                        // ą┤ą░čéčī booster čüčéą░ą▒ąĖą╗ąĖąĘąĖčĆąŠą▓ą░čéč
  44:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(0x81);             // contrast mode
  45:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(CONTRAST);         // contrast value
  46:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(0x40);             // start line = 0
  47:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(0xAF);             // display on
  48:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(0xA6);             // ąĮąŠčĆą╝ą░ą╗čīąĮą░čÅ (ąĮąĄ ąĖąĮą▓ąĄčĆčüąĮą░čÅ)
  49:GuitarPedal/Hardware-Modules/st7565.h ****     }
  50:GuitarPedal/Hardware-Modules/st7565.h **** 
  51:GuitarPedal/Hardware-Modules/st7565.h ****     // ąÜąŠąĮčéčĆą░čüčé (electronic volume) ST7565: ą║ąŠą╝ą░ąĮą┤ą░ 0x81 + ąĘąĮą░čćąĄąĮąĖąĄ 0..63.
  52:GuitarPedal/Hardware-Modules/st7565.h ****     void SetContrast(uint8_t v)
  53:GuitarPedal/Hardware-Modules/st7565.h ****     {
  54:GuitarPedal/Hardware-Modules/st7565.h ****         if(v > 0x3F)
  55:GuitarPedal/Hardware-Modules/st7565.h ****             v = 0x3F;
  56:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(0x81);
  57:GuitarPedal/Hardware-Modules/st7565.h ****         transport_.SendCommand(v);
  58:GuitarPedal/Hardware-Modules/st7565.h ****     }
  59:GuitarPedal/Hardware-Modules/st7565.h **** 
  60:GuitarPedal/Hardware-Modules/st7565.h ****     size_t Width() const { return width; }
  61:GuitarPedal/Hardware-Modules/st7565.h ****     size_t Height() const { return height; }
  62:GuitarPedal/Hardware-Modules/st7565.h **** 
  63:GuitarPedal/Hardware-Modules/st7565.h ****     void DrawPixel(uint_fast8_t x, uint_fast8_t y, bool on)
  64:GuitarPedal/Hardware-Modules/st7565.h ****     {
  65:GuitarPedal/Hardware-Modules/st7565.h ****         if(x >= width || y >= height)
  66:GuitarPedal/Hardware-Modules/st7565.h ****             return;
  67:GuitarPedal/Hardware-Modules/st7565.h ****         if(on)
  68:GuitarPedal/Hardware-Modules/st7565.h ****             buffer_[x + (y / 8) * width] |= (1 << (y % 8));
  69:GuitarPedal/Hardware-Modules/st7565.h ****         else
  70:GuitarPedal/Hardware-Modules/st7565.h ****             buffer_[x + (y / 8) * width] &= ~(1 << (y % 8));
  71:GuitarPedal/Hardware-Modules/st7565.h ****     }
  72:GuitarPedal/Hardware-Modules/st7565.h **** 
  73:GuitarPedal/Hardware-Modules/st7565.h ****     void Fill(bool on)
  74:GuitarPedal/Hardware-Modules/st7565.h ****     {
  75:GuitarPedal/Hardware-Modules/st7565.h ****         for(size_t i = 0; i < sizeof(buffer_); i++)
  76:GuitarPedal/Hardware-Modules/st7565.h ****             buffer_[i] = on ? 0xFF : 0x00;
  77:GuitarPedal/Hardware-Modules/st7565.h ****     }
