  39:../VCOM-G1/GuitarPedal/libDaisy/src/hid/switch.h ****     \param update_rate Does nothing. Backwards compatibility until next breaking update.
  40:../VCOM-G1/GuitarPedal/libDaisy/src/hid/switch.h ****     \param t switch type -- Default: TYPE_MOMENTARY
  41:../VCOM-G1/GuitarPedal/libDaisy/src/hid/switch.h ****     \param pol switch polarity -- Default: POLARITY_INVERTED
  42:../VCOM-G1/GuitarPedal/libDaisy/src/hid/switch.h ****     \param pu switch pull up/down -- Default: PULL_UP
  43:../VCOM-G1/GuitarPedal/libDaisy/src/hid/switch.h ****     */
  44:../VCOM-G1/GuitarPedal/libDaisy/src/hid/switch.h ****     void Init(Pin        pin,
  45:../VCOM-G1/GuitarPedal/libDaisy/src/hid/switch.h ****               float      update_rate,
