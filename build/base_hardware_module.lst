   8:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h **** namespace daisy
   9:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h **** {
  10:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h **** /** 
  11:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  * Support for I2S Audio Protocol with different bit-depth, samplerate options
  12:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  * Allows for master or slave, as well as freedom of selecting direction, 
  13:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  * and other behavior for each peripheral, and block.
  14:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  * 
  15:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  * DMA Transfer commands must use buffers located within non-cached memory or use cache maintenance
  16:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  * To declare an unitialized global element in the DMA memory section:
  17:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  *    int32_t DSY_DMA_BUFFER_SECTOR my_buffer[96];
  18:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  *
  19:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  * Callback functions will be called once per half of the buffer. In the above example, 
  20:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  * the callback function would be called once for every 48 samples.
  21:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  * 
  22:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  * Use SAI Handle like this:
  23:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  * 
  24:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  *  SaiHandle::Config sai_config;
  25:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  *  sai_config.periph          = SaiHandle::Config::Peripheral::SAI_1;
  26:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  *  sai_config.sr              = SaiHandle::Config::SampleRate::SAI_48KHZ;
  27:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  *  sai_config.bit_depth       = SaiHandle::Config::BitDepth::SAI_24BIT;
  28:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  *  sai_config.a_sync          = SaiHandle::Config::Sync::MASTER;
  29:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  *  sai_config.b_sync          = SaiHandle::Config::Sync::SLAVE;
  30:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  *  sai_config.a_dir           = SaiHandle::Config::Direction::RECEIVE;
  31:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  *  sai_config.b_dir           = SaiHandle::Config::Direction::TRANSMIT;
  32:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  *  sai_config.pin_config.fs   = {DSY_GPIOE, 4};
  33:../VCOM-G1/GuitarPedal/libDaisy/src/per/sai.h ****  *  sai_config.pin_config.mclk = {DSY_GPIOE, 2};
ARM GAS  C:\Users\vinok\AppData\Local\Temp\ccSVmXie.s 			page 267


